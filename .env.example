# QWeather API Configuration
# Get your API key from: https://console.qweather.com

# QWeather API Key (required)
QWEATHER_API_KEY=your_api_key_here

# QWeather API Host (optional, defaults to devapi.qweather.com for free tier)
# For paid tier, use: api.qweather.com
QWEATHER_API_HOST=devapi.qweather.com
